Column[{Style["3-loops Vacuum", Bold], 
  Graphics[{Thickness[Large], Arrow[{{0, 1}, {-1, -0.5}}], 
    Arrow[{{-1, -0.5}, {1, -0.5}}], Arrow[{{1, -0.5}, {0, 1}}], 
    Arrow[{{0, 1}, {0, 0}}], Arrow[{{-1, -0.5}, {0, 0}}], 
    Arrow[{{1, -0.5}, {0, 0}}], Text["k1", {-0.6, 0.35}], 
    Text["k2", {0, -0.7}], Text["k3", {0.6, 0.35}], Text["k6", {0.1, 1/2}], 
    Text["k4", {-1/2, -0.15}], Text["k5", {0.55, -0.15}], PointSize[0.02], 
    Point[{{0, 1}, {-1, -0.5}, {1, -0.5}, {0, 0}}]}, PlotRange -> 1.3, 
   ImageSize -> 250]}]
