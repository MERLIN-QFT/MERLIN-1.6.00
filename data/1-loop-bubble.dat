Column[{Style["1-loop Bubble", Bold], "Invariants: s1 = p1^2", 
  Graphics[{Thickness[Large], Arrow[{{-1.5, 0}, {-0.5, 0}}], 
    Arrow[{{0.5, 0}, {1.5, 0}}], 
    Arrow[BezierCurve[{{-0.5, 0}, {0, 1}, {0.5, 0}}]], 
    Arrow[BezierCurve[{{0.5, 0}, {0, -1}, {-0.5, 0}}]], 
    Text["p1", {-1., 0.15}], Text["p1", {1., 0.15}], Text["k1", {0, 0.8}], 
    Text["k2", {0, -0.8}], PointSize[0.02], Point[{{-0.5, 0}, {0.5, 0}}]}, 
   PlotRange -> 2, ImageSize -> 250]}]
